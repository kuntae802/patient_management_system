# api/.env.example — FastAPI 환경변수 (실값은 .env, 커밋 금지)
# 로컬: `supabase start` 출력값 사용. 🚫 SUPABASE_SECRET_KEY 값 커밋 금지.

# Supabase (로컬 기본 — 클라우드 데모 시 교체)
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
# supabase-py 베이스(GoTrue Auth admin·Storage 서명 URL용, Story 5.8). 클라우드 데모 시 프로젝트 URL.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SECRET_KEY=

# 서브패스·CORS (project-context 준수)
API_ROOT_PATH=/patient_management_system/api
CORS_ORIGINS=http://localhost:3000,https://kuntae802.mooo.com
