# ─────────────────────────────────────────────────────────────
# patient_management_system — 루트 환경변수 예시
# 실값은 .env(.gitignore로 차단)에 두고, 이 파일은 "키만" 커밋한다.
# 🚫 시크릿(secret/service_role 키, DB 비밀번호) 절대 커밋 금지.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──
# 로컬 개발: `supabase start` 출력값 사용 (CLI는 아직 anon/service_role 발급)
#   - NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY ← 로컬 anon key 매핑
#   - SUPABASE_SECRET_KEY                 ← 로컬 service_role key 매핑 (서버 전용)
# 데모/배포: 클라우드 프로젝트의 신규 키(sb_publishable_… / sb_secret_…) 사용
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_URL=
SUPABASE_JWKS_URL=

# ── 서브패스 전파 (4개 서피스 일관) ──
NEXT_PUBLIC_BASE_PATH=/patient_management_system
API_ROOT_PATH=/patient_management_system/api
CORS_ORIGINS=https://kuntae802.mooo.com

# ── 배포 (홈서버 110 컨테이너 호스트 포트 — 108 nginx가 프록시) ──
WEB_HOST_BIND=192.168.219.110:3002
API_HOST_BIND=192.168.219.110:8060
TZ=Asia/Seoul
